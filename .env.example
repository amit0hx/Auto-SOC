# Auto-SOC Environment Configuration
# Copy this file to .env and fill in your actual keys
# This file is in .gitignore — will NEVER be committed to GitHub

# Gemini API (for LLM playbooks) — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# GitHub PAT (for pushing code) — https://github.com/settings/tokens?type=beta
GITHUB_PAT=your_github_token_here
